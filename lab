#!/usr/bin/env bash
# lab — 小白只記一個字的 lab 包裝器
#   ./lab 3          跑 step 3
#   ./lab fix 3      把 solutions/step3 拷回 steps/（卡住救援）
#   ./lab check      環境體檢（key / shop / sdk）
set -euo pipefail
cd "$(dirname "$0")"
export PYTHONPATH="$PWD${PYTHONPATH:+:$PYTHONPATH}"  # 讓 steps/ 找得到 common.py
# Cloud Shell 斷線後 export 會消失 → 若之前 ./lab save 過，自動載回身分
[ -f "$HOME/.lab_env" ] && . "$HOME/.lab_env"
SHOP="${SHOP_URL:-https://shop.leapcore.tw}"

step_file() { ls steps/step"$1"_*.py 2>/dev/null | head -1; }
sol_file()  { ls solutions/step"$1"_*.py 2>/dev/null | head -1; }

cmd_run() {
  local n="$1" f
  f="$(step_file "$n")"
  [ -n "$f" ] || { echo "❌ 找不到 step ${n}（有 1–8，外加選做 9）"; exit 1; }
  echo "▶️  跑 ${f}"
  if [ "$n" = "9" ]; then
    echo "🎤 啟動語音網頁 agent（uvicorn 0.0.0.0:8080）…"
    echo "   👉 Cloud Shell：右上『網頁預覽』→『透過以下連接埠預覽 8080』即可開"
    echo "   👉 想自訂埠：PORT=xxxx ./lab 9  ｜ 停掉：Ctrl-C"
  fi
  exec uv run python "$f"
}

cmd_fix() {
  local n="$1" s d
  s="$(sol_file "$n")"; [ -n "$s" ] || { echo "❌ 沒有 step $n 的解答"; exit 1; }
  d="steps/$(basename "$s")"
  cp "$s" "$d"
  echo "✅ 已把解答拷到 $d"
  echo "   現在跑：./lab $n"
}

cmd_check() {
  echo "🩺 環境體檢"
  echo "──────────────────────────────"
  # 1) GEMINI_API_KEY
  if [ -n "${GEMINI_API_KEY:-}" ]; then
    echo "✅ GEMINI_API_KEY 已設定"
  else
    echo "❌ GEMINI_API_KEY 沒設定 → 到 ai.dev/apikey 拿免費金鑰，貼：export GEMINI_API_KEY=AIza...（你的金鑰）"
  fi
  # 2) STUDENT_ID
  if [ -n "${STUDENT_ID:-}" ]; then
    echo "✅ STUDENT_ID = ${STUDENT_ID}"
  else
    echo "❌ STUDENT_ID 沒設定 → export STUDENT_ID=u0xx（報到頁那個；任意英數也可，例如 jimmy-test）"
  fi
  # 3) shop /health（${SHOP} 一定要大括號：$SHOP 後接全形字在 macOS bash 3.2 會誤判變數名）
  if curl -fsS --max-time 8 "${SHOP}/health" >/dev/null 2>&1; then
    echo "✅ 商城連得上（${SHOP}）"
  else
    echo "❌ 連不到商城 ${SHOP} → 檢查網路；或 export SHOP_URL=<備援網址>"
  fi
  # 4) sdk import
  if uv run python -c "import google.antigravity" >/dev/null 2>&1; then
    echo "✅ Antigravity SDK 可 import"
  else
    echo "❌ SDK 還沒裝好 → 先跑 ./setup.sh（或 uv sync）"
  fi
  echo "──────────────────────────────"
  echo "💡 用免費金鑰？每個 model 每分鐘約 5 次上限；./lab 會自動換 model 續用，撞到就等約 60 秒。"
}

cmd_save() {
  : "${GEMINI_API_KEY:?❌ 還沒設 GEMINI_API_KEY，先 export 再 ./lab save}"
  : "${STUDENT_ID:?❌ 還沒設 STUDENT_ID，先 export 再 ./lab save}"
  printf 'export GEMINI_API_KEY=%s\nexport STUDENT_ID=%s\n' "$GEMINI_API_KEY" "$STUDENT_ID" > "$HOME/.lab_env"
  chmod 600 "$HOME/.lab_env"
  echo "✅ 身分已存到 ~/.lab_env"
  echo "   之後就算 Cloud Shell 斷線重開，./lab 會自動載回，不必再貼 export。"
}

case "${1:-}" in
  ""|play) exec uv run python play.py ;;   # 裸跑 ./lab = 直接進互動模式
  check)   cmd_check ;;
  save)    cmd_save ;;
  fix)     [ -n "${2:-}" ] || { echo "用法：./lab fix N"; exit 1; }; cmd_fix "$2" ;;
  -h|--help)
    echo "用法：./lab            → 🛒 直接跟你的購物 agent 對話（主玩法）"
    echo "     ./lab check       → 環境體檢"
    echo "     ./lab save        → 把目前 key+代號存起來（防 Cloud Shell 斷線要重貼）"
    echo "     ./lab 1–8         → （進階）一步步學怎麼自己把這隻 agent 建出來"
    echo "     ./lab 9           → （選做）語音網頁版"
    echo "     ./lab fix N       → 卡住時把解答拷回來"
    ;;
  *)       cmd_run "$1" ;;
esac
